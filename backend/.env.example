PORT=4000
NODE_ENV=development

# MongoDB is the durable source of truth for users, products, and orders.
# MONGODB_URI is also supported if your host/provider uses that name.
MONGO_URI=mongodb://localhost:27017/medkit

# Redis stores rebuildable product and quote caches.
REDIS_URL=redis://localhost:6379

# Stripe test-mode credentials for local development.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# CLIENT_URL is used in Stripe success/cancel redirects.
CLIENT_URL=http://localhost:3000
# FRONTEND_URL is also supported as a fallback for CLIENT_URL.

# Comma-separated browser origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:3000

# Set to false only when you never want empty deployments to create demo products.
AUTO_SEED_PRODUCTS=true

# Request observability.
# REQUEST_LOGS=false disables per-request JSON logs.
# SLOW_REQUEST_MS controls which completed requests are retained in /metrics.
# METRICS_TOKEN makes /metrics require Authorization: Bearer <token>.
REQUEST_LOGS=true
SLOW_REQUEST_MS=500
# METRICS_TOKEN=

JWT_SECRET=replace_with_a_long_random_value
